		educators.Add(new Educator("Per", "Hansen", new DateTime(1970, 7, 20), "Per@UIA.no", 20,100));
		educators.Add(new Educator("Lise", "Olsen", new DateTime(1965, 11, 30), "lise@NTNU.no", 20,100));
		educators.Add(new Educator("Nina", "Larsen", new DateTime(1960, 1, 25), "nina@UIT.no", 20,100)); 
	}

	private void DeleteRow(Educator RemoveEducator)
	{
		if (RemoveEducator != null)
		{
			educators.Remove(RemoveEducator);
		}
		else
		{
			throw new ArgumentNullException(nameof(RemoveEducator), "Educator to remove cannot be null.");
		}
	}

