@inherits LayoutComponentBase
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div>
                Filtrer på dato:
                <input id="startDate" type="date" placeholder="dato fra" @bind="StartDate"/>
                til: 
				<input id="endDate" type="date" placeholder="dato til" @bind="EndDate"/>
            </div>
            
            <a href="profile"><i id="profile" class="bi bi-person" style="font-size: 2rem;">
                <span id="profileHelp">Edit profile</span>
            </i></a>

        </div>

        <article class="content px-4">
            <CascadingValue Value="StartDate" Name="StartDate">
				<CascadingValue Value="EndDate" Name="EndDate">
            @Body
				</CascadingValue>
                </CascadingValue>
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {

	public DateTime StartDate { get; set; }
	public DateTime EndDate { get; set; }

	protected override void OnInitialized()
	{
		StartDate = CalculateStartDate();
		EndDate = CalculateEndDate();
		System.Diagnostics.Debug.WriteLine($"MainLayout - StartDate: {StartDate}, EndDate: {EndDate}");
		StateHasChanged();
	}

	private DateTime CalculateStartDate()
	{
		int currentYear = int.Parse(DateOnly.FromDateTime(DateTime.Now).ToString("yyyy"));
		int currentMonth = int.Parse(DateOnly.FromDateTime(DateTime.Now).ToString("MM"));

		if (currentMonth > 6)
		{
			return new DateTime(currentYear, 8, 1);
		}
		else
		{
			return new DateTime(currentYear - 1, 8, 1);
		}
	}

	private DateTime CalculateEndDate()
	{
		int currentYear = int.Parse(DateOnly.FromDateTime(DateTime.Now).ToString("yyyy"));
		int currentMonth = int.Parse(DateOnly.FromDateTime(DateTime.Now).ToString("MM"));

		if (currentMonth > 6)
		{
			return new DateTime(currentYear + 1, 6, 30);
		}
		else
		{
			return new DateTime(currentYear, 6, 30);
		}
	}
}
