@page "/profile"
@using System.ComponentModel.DataAnnotations
@using Classes
@inject EducatorList educators
@rendermode InteractiveServer

<!--Mulig døpe om denne siden til profile
	koble denne lokale klassen og formen til en global klasse og service for å lagre data i database
	Kanskje lagre den i en liste i en service. 
-->
<head>
	<style>
		input {
			margin-bottom: 10px;
			width: 20%;
			height: 30px;
			font-size: 16px;
			padding: 5px;
		}
	</style>
</head>

<PageTitle>Profile</PageTitle>

<h1>Profil</h1>
	<input type="text" placeholder="Fornavn" @bind="inputModel.FirstName" /><br />
<input type="text" placeholder="Etternavn" @bind="inputModel.LastName" />
<br />
<input type="email" placeholder="E-post" @bind="inputModel.Email" />
<br />
<input type="date" placeholder="fødselsdato" @bind="inputModel.BirthDate" />
<br />
<input type="text" placeholder="Utdanningsbakgrunn" @bind="inputModel.EducationBackground" />
<br />
<input type="text" placeholder="Spesialisering" @bind="inputModel.Specialization" />
<br />
<button class="btn btn-primary" @onclick="() => AddProfile()" style="width:20%">Submit</button>


@code {
	private class InputModel
	{
		[Required]
		public string FirstName { get; set; } = string.Empty;
		[Required]
		public string LastName { get; set; } = string.Empty;
		[Required]
		[EmailAddress]
		public string Email { get; set; } = string.Empty;
		[Required]
		public DateOnly BirthDate { get; set; } = DateOnly.FromDateTime(DateTime.Now);
		[Required]
		public string EducationBackground { get; set; } = string.Empty;
		[Required]
		public string Specialization { get; set; } = string.Empty;		
	}

	private InputModel inputModel = new InputModel();

	private void AddProfile()
	{
		Educator educator = new Educator
		(
			inputModel.FirstName,
			inputModel.LastName,
			inputModel.BirthDate.ToDateTime(TimeOnly.MinValue),
			inputModel.Email,
			20,
			100,
			inputModel.EducationBackground,
			inputModel.Specialization
		);
		educators.AddEducator(educator);
		// Clear the form
		inputModel = new InputModel();
	}
}
