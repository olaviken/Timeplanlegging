@inherits LayoutComponentBase
@inject Components.Services.DateService dateService
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div>
                Filtrer på dato:
                <input id="startDate" type="date" placeholder="dato fra" @bind="dateService.SchoolYearStartDate" @bind:after="() => dateService.SetStartDate(dateService.SchoolYearStartDate)" bind:event="oninput" />
                til: 
                <input id="endDate" type="date" placeholder="dato til" @bind="dateService.SchoolYearEndDate" @bind:after="() => dateService.SetEndDate(dateService.SchoolYearEndDate)" bind:event="oninput" />
            </div>
            
            <a href="profile"><i id="profile" class="bi bi-person" style="font-size: 2rem;">
                <span id="profileHelp">Edit profile</span>
            </i></a>

        </div>
					
                <article class="content px-4">
                 @Body
				
                </article>
            
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {

    


    protected override void OnInitialized()
    {
        dateService.CalculateStartDate();
		dateService.CalculateEndDate();
    }


}
