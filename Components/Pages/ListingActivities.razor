@page "/ListingActivities"
@using System.ComponentModel.DataAnnotations
@inject Classes.Interfaces.IActivities activities
@using Classes
@rendermode InteractiveServer
@inject IJSRuntime JS


<h3>Undervisnings aktivitet</h3>

<table class="table">
	<thead>
		<tr>
			<th>ID</th>
			<th>Dato</th>
			<th>Aktivitets navn</th>
			<th> Antall timer</th>
			<th> Beregnet tid</th>
			<th> Kategori</th>
			<th>Studieretning</th>

			<th>Beskrivelse</th>
			<th>Forelesers fornavn</th>
			<th>Forelesers etternavn</th>
			<th></th>
			<th></th>
		</tr>
	</thead>
	<tbody>
		<tr id="Editrow">
			<td>@newActivity.ActivityID</td>
			<td><input id="InputDate" type="date" @bind="newActivity.ActivityDate" /></td>
			<td><input id="InputActivityName" type="text" @bind="newActivity.ActivityName" /> </td>
			<td><input id="InputNumberOfHours" type="number" @bind="newActivity.ActivityHours" /></td>
			<td> @newActivity.CalculatedHours </td>
			<td><input id="InputCategory" type="text" @bind="newActivity.ActivityCategory" />  </td> 
			<td><input id="InputStudyProgram" type="text" @bind="newActivity.Field" /> </td>
			<td><input id="InputDescription" type="text" @bind="newActivity.ActivityDescription" /></td>
			<td><input id="InputEducatorFirstName" type="text" @bind="newActivity.EducatorFirstName"  /> </td>
			<td><input id="InputEducatorLastName" type="text" @bind="newActivity.EducatorLastName" /> </td>
			<td> 
				<button class="btn btn-primary" @onclick="() => AddRow()"><i class="bi bi-plus-lg"></i></button>
			</td>
		</tr>
		@if (activities == null || activities.CountActivities() == 0)
		{
			<tr>
				<td colspan="5"> Ingen aktiviteter lagt til. </td>
			</tr>
		}
		else
		{
			@foreach (var activity in activities.GetActivities())
			{
				<tr>
					<td> @activity.ActivityID </td>
					<td> @activity.ActivityDate </td>
					<td> @activity.ActivityName </td>
					<td> @activity.ActivityHours </td>
					<td> @activity.CalculatedHours </td>
					<td> @activity.ActivityCategory </td>
					<td> @activity.Field </td>
					<td> @activity.ActivityDescription </td>
					<td> @activity.EducatorFirstName </td>
					<td> @activity.EducatorLastName </td>
					<td>
						<button class="btn btn-primary" @onclick="() => DeleteRow(activity)"><i class="bi bi-trash"></i></button>
					</td>
					<td>
						<button class="btn btn-primary" @onclick="() => EditRow(activity)"><i class="bi bi-pencil"></i></button>
					</td>
				</tr>
			}
		}
		
	</tbody>
</table>

@code {


	private Activity newActivity = new Activity();

	private void AddRow()
	{
		if (activities.FindActivityByID(newActivity.ActivityID) != null)
		{
			Activity existingActivity = newActivity;
			activities.UpdateActivity(existingActivity);
		}
		else
		{
			activities.AddActivity(newActivity);
		}

	}

	private void DeleteRow(Activity activity)
	{
		if(activity != null)
		{
			activities.RemoveActivity(activity);
		}
		
	}

	private void EditRow(Activity activity)
	{
		newActivity.ActivityID = activity.ActivityID;
		newActivity.ActivityDate = activity.ActivityDate;
		newActivity.ActivityName = activity.ActivityName;
		newActivity.ActivityHours = activity.ActivityHours;
		newActivity.Field = activity.Field;
		newActivity.ActivityDescription = activity.ActivityDescription;
		newActivity.EducatorFirstName = activity.EducatorFirstName;
		newActivity.EducatorLastName = activity.EducatorLastName;		
	}

}
