@page "/profile"
@using System.ComponentModel.DataAnnotations
@using Classes
@inject EducatorList educators
@rendermode InteractiveServer

<!--Mulig døpe om denne siden til profile
	koble denne lokale klassen og formen til en global klasse og service for å lagre data i database
	Kanskje lagre den i en liste i en service. 
-->
<PageTitle>Profile</PageTitle>

<h1>Profil</h1>
<EditForm Model="educator" class="form-container">
	<input type="text" class="form-control" placeholder="Fornavn" @bind="" />
	<input type="text" class="form-control" placeholder="Etternavn" @bind="" />
	<input type="email" class="form-control" placeholder="E-post" @bind="" />
	<input type="date" class="form-control" placeholder="fødselsdato" @bind="" />
	
	<select class="form-control" placeholder="Fagenhet" @bind="">
		<option value="" disabled selected>Fagenhet</option>
		<option value="Sykepleie">Sykepleie</option>
		<option value="Spesialsykepleie">Spesialsykepleie</option>
		<option value="Fysioterapi">Fysioterapi</option>
		<option value="Ergoterapi">Ergoterapi</option>
		<option value="Audiologi">Audiologi</option> 
		<!--To do list fremover:
			Endre dette til en liste som hentes fra database-->
		
	</select>
	<input type="text" class="form-control" placeholder="Utdanningsbakgrunn" @bind="" />
	<input type="text" class="form-control" placeholder="Spesialisering" @bind="" />
	<button class="form-button" >Submit</button>
	<!-- 
		To do fremover:
			Lage en funksjon som lagrer dataene først i en liste, deretter sender de til en database (Database ikke implementert enda). Fokusere på UI først.

	-->
</EditForm>


@code {
	public class Educator {
		public required string firstName { get; set; } = string.Empty;
		public required string lastName { get; set; } = string.Empty;
		public required DateTime birthDate { get; set; }
		public required string email { get; set; } = string.Empty;
		public required string position { get; set; } = string.Empty;
		public required string subjectUnit { get; set; } = string.Empty;
		public required string education { get; set; } = string.Empty;
		public required string specialization { get; set; } = string.Empty;
		
	}

	public Educator educator = new Educator
		{
			firstName = string.Empty,
			lastName = string.Empty,
			birthDate = DateTime.Now,
			email = string.Empty,
			position = string.Empty,
			subjectUnit = string.Empty,
			education = string.Empty,
			specialization = string.Empty
		};
}
